---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { getAllBlogPosts } from '@/lib/blog';
import { DEFAULT_LOCALE, type Locale } from '@/lib/i18n';

const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const posts = await getAllBlogPosts(locale);
const featuredPost = posts[0];
const secondaryPosts = posts.slice(1);
const allTags = Array.from(new Set(posts.flatMap((post) => post.data.tags ?? []))).slice(0, 8);

const pageTitle = locale === 'es' ? 'Blog | Velour' : 'Blog | Velour';
const pageDescription =
  locale === 'es'
    ? 'Estrategias de monetizacion, conversion en DMs y gestion de audiencia para creadoras de alto rendimiento.'
    : 'Monetization, DM conversion and audience management strategies for high-performance creators.';
---

<DefaultLayout locale={locale} title={pageTitle} description={pageDescription}>
  <section class="hero-padding container space-y-8 md:space-y-10">
    <div class="space-y-3">
      <p class="text-xs uppercase tracking-[0.18em] text-muted-foreground">
        {locale === 'es' ? 'Insights de Velour' : 'Velour Insights'}
      </p>
      <h1 class="text-4xl tracking-tight md:text-5xl">
        {locale === 'es'
          ? 'Estrategia real para escalar ingresos'
          : 'Real strategy to scale revenue'}
      </h1>
      <p class="max-w-3xl text-muted-foreground">
        {locale === 'es'
          ? 'Analisis tactico para creadoras que quieren conversion estable, retencion y control operativo.'
          : 'Tactical analysis for creators who want stable conversion, retention and operational control.'}
      </p>
    </div>

    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {allTags.map((tag) => (
          <span class="rounded-full border border-border/70 px-3 py-1 text-xs text-muted-foreground">
            {tag}
          </span>
        ))}
      </div>
    )}

    {featuredPost && (
      <a
        href={`/blog/${featuredPost.id}`}
        class="group grid overflow-hidden rounded-2xl border border-border/70 bg-card/45 transition-colors hover:border-foreground/30 md:grid-cols-[1.3fr_1fr]"
      >
        <img
          src={featuredPost.data.coverImage ?? '/images/homepage/hero/new1.webp'}
          alt={featuredPost.data.title}
          class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105 md:h-full"
        />
        <div class="flex flex-col justify-between p-6">
          <div class="space-y-3">
            <p class="text-xs uppercase tracking-[0.16em] text-muted-foreground">
              {locale === 'es' ? 'Lectura destacada' : 'Featured read'}
            </p>
            <h2 class="text-2xl leading-tight tracking-tight md:text-3xl">
              {featuredPost.data.title}
            </h2>
            <p class="text-sm text-muted-foreground md:text-base">
              {featuredPost.data.description}
            </p>
          </div>
          <span class="mt-5 text-sm font-medium">
            {locale === 'es' ? 'Leer analisis completo' : 'Read full analysis'}
          </span>
        </div>
      </a>
    )}

    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        secondaryPosts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group overflow-hidden rounded-2xl border border-border/60 bg-card/60 transition-colors hover:border-foreground/25"
          >
            <img
              src={post.data.coverImage ?? '/images/homepage/hero/new1.webp'}
              alt={post.data.title}
              class="h-44 w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="space-y-3 p-5">
              <p class="text-xs uppercase tracking-[0.16em] text-muted-foreground">
                {new Date(post.data.date).toLocaleDateString(
                  locale === 'es' ? 'es-ES' : 'en-US',
                  {
                    day: '2-digit',
                    month: 'short',
                    year: 'numeric',
                  },
                )}
              </p>
              <h2 class="text-xl leading-tight tracking-tight">{post.data.title}</h2>
              <p class="line-clamp-3 text-sm text-muted-foreground">{post.data.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</DefaultLayout>
