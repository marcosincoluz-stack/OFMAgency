---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { SITE_TITLE } from '../consts';
import { getAllProjects } from '@/lib/projects';
import { getAllServices } from '@/lib/services';

// Import all sections
import { Hero } from '@/components/sections/hero';
import { AboutIntro } from '@/components/sections/about-intro';
import { Features } from '@/components/sections/features';
import { BentoDemo } from '@/components/sections/bento-demo';
import { CaseStudies } from '@/components/sections/case-studies';
import { Logos } from '@/components/sections/logos';
import { Services } from '@/components/sections/services';
import { Process } from '@/components/sections/process';
import { Cta } from '@/components/sections/cta';
import { Testimonials } from '@/components/sections/testimonials';
import { ContactForm } from '@/components/sections/contact-form';
import { OurProcess } from '@/components/sections/our-process';
import { ProjectsGrid } from '@/components/sections/projects-grid';
import { Services as ServicesSection } from '@/components/sections/services-section';
import { ProjectGallery } from '@/components/sections/project-gallery';
import { ProjectHero } from '@/components/sections/project-hero';
import { ProjectOverview } from '@/components/sections/project-overview';
import { ServiceHero } from '@/components/sections/service-hero';
import { ServiceWhatYouGet } from '@/components/sections/service-what-you-get';
import { ServiceFeaturedWork } from '@/components/sections/service-featured-work';
import NotFound from '@/components/sections/not-found';

// UI Components
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Logo1 } from '@/components/icons/logos';
import { LogoDesignIcon } from '@/components/icons/service-icons';

const allProjects = await getAllProjects();
const allServices = await getAllServices();

const heroProjects = allProjects.slice(0, 4);
const caseStudyProjects = allProjects.slice(0, 3);
const logoProjects = allProjects.slice(0, 6);

const values = [
  { title: 'Clarity', description: 'Design that communicates instantly.' },
  { title: 'Simplicity', description: 'Logos that are memorable and versatile.' },
  { title: 'Quality', description: 'Every detail refined.' },
];

const pageTitle = 'Bloques | ' + SITE_TITLE;
---

<DefaultLayout title={pageTitle} description="Muestra de todos los bloques disponibles en el proyecto.">
  <div class="py-20 text-center bg-muted">
    <h1 class="text-4xl font-bold">Biblioteca de Bloques</h1>
    <p class="text-muted-foreground mt-2">Explora visualmente todas las secciones del sistema.</p>
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Hero</div>
    <Hero projects={heroProjects} client:load />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Features</div>
    <Features client:load />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Bento Grid</div>
    <BentoDemo client:load />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: About Intro</div>
    <AboutIntro />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Case Studies</div>
    <CaseStudies projects={caseStudyProjects} client:load />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Logos</div>
    <Logos projects={logoProjects} client:load />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Services</div>
    <Services />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Process (Values)</div>
    <Process title="Our Values" steps={values} client:load />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Services Section</div>
    <ServicesSection services={allServices} />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Projects Grid</div>
    <ProjectsGrid projects={allProjects} />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Project Hero</div>
    <ProjectHero title={allProjects[0].name} image={allProjects[0].images[0]} />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Project Overview</div>
    <ProjectOverview title="Project Overview" project={allProjects[0]} />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Project Gallery</div>
    <ProjectGallery images={[allProjects[0].images[0]]} />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Service Hero</div>
    <ServiceHero title={allServices[0].name} image={allServices[0].image} />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Service What You Get</div>
    <ServiceWhatYouGet items={allServices[0].whatYouGet} />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Service Featured Work</div>
    <ServiceFeaturedWork items={caseStudyProjects} />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Our Process</div>
    <OurProcess />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Testimonials</div>
    <Testimonials />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Contact Form</div>
    <div class="container py-20">
      <ContactForm client:load />
    </div>
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: CTA</div>
    <Cta />
  </div>

  <div class="space-y-4 shadow-sm bg-background">
    <div class="p-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-widest">Bloque: Not Found</div>
    <NotFound />
  </div>

  <!-- UI Components Gallery -->
  <div class="container py-20 space-y-20">
    <div class="text-center">
      <h2 class="text-3xl font-bold">Componentes Atómicos UI</h2>
      <p class="text-muted-foreground mt-2">Estos son los bloques de construcción que forman el sistema total de +100 componentes.</p>
    </div>

    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
      <div class="space-y-4 p-6 border rounded-lg">
        <h3 class="font-bold underline">Botones</h3>
        <div class="flex flex-wrap gap-2">
          <Button>Default</Button>
          <Button variant="secondary">Secondary</Button>
          <Button variant="outline">Outline</Button>
          <Button variant="ghost">Ghost</Button>
        </div>
      </div>

      <div class="space-y-4 p-6 border rounded-lg">
        <h3 class="font-bold underline">Badges</h3>
        <div class="flex flex-wrap gap-2">
          <Badge>New</Badge>
          <Badge variant="secondary">Popular</Badge>
          <Badge variant="outline">Coming Soon</Badge>
        </div>
      </div>

      <div class="space-y-4 p-6 border rounded-lg">
        <h3 class="font-bold underline">Formularios</h3>
        <div class="space-y-2">
          <Label htmlFor="demo-input">Nombre</Label>
          <Input id="demo-input" placeholder="Escribe algo..." />
        </div>
      </div>

      <div class="space-y-4 p-6 border rounded-lg">
        <h3 class="font-bold underline">Iconos y Logotipos</h3>
        <div class="flex flex-wrap gap-4 text-primary">
          <Logo1 className="h-8 w-auto" />
          <LogoDesignIcon className="h-8 w-8" />
        </div>
        <p class="text-xs text-muted-foreground">El proyecto incluye decenas de variantes de iconos y logotipos SVG.</p>
      </div>
    </div>
  </div>
</DefaultLayout>
