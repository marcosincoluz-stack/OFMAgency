---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

import { AboutIntro } from '@/components/sections/about-intro';
import { BentoDemo } from '@/components/sections/bento-demo';
import BlogLinks from '@/components/sections/blog-links.astro';
import { CaseStudies } from '@/components/sections/case-studies';
import { Cta } from '@/components/sections/cta';
import { Hero } from '@/components/sections/hero';
import { Testimonials } from '@/components/sections/testimonials';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { getAllBlogPosts } from '@/lib/blog';
import { DEFAULT_LOCALE, type Locale } from '@/lib/i18n';
import { getAllProjects } from '@/lib/projects';

// Fetch data server-side in parallel for better performance
const locale: Locale = Astro.locals.locale ?? DEFAULT_LOCALE;
const allProjects = await getAllProjects();
const blogPosts = await getAllBlogPosts(locale);
const compactProjects = allProjects.map((project) => ({
  id: project.id,
  name: project.name,
  slug: project.slug,
  logo: project.logo,
  logoImage: project.logoImage,
  forceWhiteLogo: project.forceWhiteLogo,
  logoClassName: project.logoClassName,
  imageClassName: project.imageClassName,
  hideLogoOverlay: project.hideLogoOverlay,
  category: project.category,
  url: project.url,
  title: project.title,
  description: project.description,
  images: project.images,
}));

// Use ProjectFrontmatter (serializable) instead of EnrichedProject (has React components)
const heroProjects = compactProjects.slice(0, 4);
const caseStudyProjects = [
  compactProjects.find((project) => project.slug === 'nextdock'),
  compactProjects.find((project) => project.slug === 'nextdock'),
].filter(Boolean);
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Hero projects={heroProjects} client:idle />
  <div class="[content-visibility:auto] [contain-intrinsic-size:800px]">
    <AboutIntro />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:900px]">
    <BentoDemo client:visible />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:1100px]">
    <CaseStudies projects={caseStudyProjects} client:visible />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:860px]">
    <Testimonials />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:680px]">
    <BlogLinks posts={blogPosts} locale={locale} />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:420px]">
    <Cta />
  </div>
</DefaultLayout>
