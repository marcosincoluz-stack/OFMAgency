---
import { FaqSection } from '@/components/sections/faq';
import { SITE_TITLE } from '@/consts';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const pageTitle = 'FAQ | ' + SITE_TITLE;
const pageDescription =
  'Respuestas claras sobre rol de la modelo, promocion, pagos, split y tipo de contenido.';
---

<DefaultLayout title={pageTitle} description={pageDescription}>
  <section class="section-padding container space-y-4 pb-0!">
    <p class="text-muted-foreground text-xs font-medium tracking-[0.24em] uppercase">FAQ</p>
    <h1 class="text-4xl leading-tight md:text-5xl">Dudas y preguntas frecuentes</h1>
    <p class="text-muted-foreground max-w-3xl text-lg">
      Respuestas directas para que sepas como trabajamos, que esperar y si este modelo encaja
      contigo.
    </p>
  </section>
  <FaqSection />
</DefaultLayout>

