---
import { AboutIntro } from '@/components/sections/about-intro';
import { BentoDemo } from '@/components/sections/bento-demo';
import BlogLinks from '@/components/sections/blog-links.astro';
import { CaseStudies } from '@/components/sections/case-studies';
import { Cta } from '@/components/sections/cta';
import { FaqSection } from '@/components/sections/faq';
import { Hero } from '@/components/sections/hero';
import { Testimonials } from '@/components/sections/testimonials';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { getAllBlogPosts } from '@/lib/blog';
import { SUPPORTED_LOCALES, isLocale, type Locale } from '@/lib/i18n';
import { getDictionary } from '@/lib/i18n-dictionary';
import { getAllProjects } from '@/lib/projects';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!isLocale(localeParam)) {
  return Astro.redirect('/es', 302);
}

const locale: Locale = localeParam;
const market = Astro.locals.market;
const dict = getDictionary(locale);

const allProjects = await getAllProjects(locale);
const blogPosts = await getAllBlogPosts(locale);
const heroProjects = allProjects.slice(0, 4).map((project) => ({
  id: project.id,
  name: project.name,
  slug: project.slug,
  logo: project.logo,
  logoImage: project.logoImage,
  forceWhiteLogo: project.forceWhiteLogo,
  logoClassName: project.logoClassName,
  imageClassName: project.imageClassName,
  hideLogoOverlay: project.hideLogoOverlay,
  category: project.category,
  url: project.url,
  images: project.images.slice(0, 1),
}));

const nextdock = allProjects.find((project) => project.slug === 'nextdock');
const caseStudyProjects = nextdock
  ? [
      {
        id: nextdock.id,
        name: nextdock.name,
        slug: nextdock.slug,
        logo: nextdock.logo,
        category: nextdock.category,
        url: nextdock.url,
        title: nextdock.title,
        description: nextdock.description,
        images: nextdock.images,
      },
    ]
  : [];
---

<DefaultLayout
  locale={locale}
  title={dict.pages.home.title}
  description={dict.pages.home.description}
>
  <Hero projects={heroProjects} locale={locale} client:load />
  <div class="[content-visibility:auto] [contain-intrinsic-size:800px]">
    <AboutIntro locale={locale} />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:900px]">
    <BentoDemo locale={locale} market={market} client:visible />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:1100px]">
    <CaseStudies projects={caseStudyProjects} locale={locale} client:visible />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:860px]">
    <Testimonials locale={locale} />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:680px]">
    <BlogLinks posts={blogPosts} locale={locale} />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:420px]">
    <Cta locale={locale} />
  </div>
  <div class="[content-visibility:auto] [contain-intrinsic-size:980px]">
    <FaqSection locale={locale} />
  </div>
</DefaultLayout>
