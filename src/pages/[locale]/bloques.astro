---
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Hero } from '@/components/sections/hero';
import { AboutIntro } from '@/components/sections/about-intro';
import { BentoDemo } from '@/components/sections/bento-demo';
import { ContactForm } from '@/components/sections/contact-form';
import { getAllProjects } from '@/lib/projects';
import { SUPPORTED_LOCALES, isLocale, type Locale } from '@/lib/i18n';
import { getDictionary } from '@/lib/i18n-dictionary';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!isLocale(localeParam)) {
  return Astro.redirect('/es', 302);
}

const locale: Locale = localeParam;
const market = Astro.locals.market;
const dict = getDictionary(locale);
const allProjects = await getAllProjects(locale);
const heroProjects = allProjects.slice(0, 4);
---

<DefaultLayout locale={locale} title={dict.pages.blocks.title} description={dict.pages.blocks.description}>
  <section class="hero-padding container text-center">
    <h1 class="text-5xl md:text-6xl lg:text-7xl">{locale === 'es' ? 'Bloques UI' : 'UI Blocks'}</h1>
  </section>

  <Hero projects={heroProjects} locale={locale} client:load />
  <AboutIntro locale={locale} />
  <BentoDemo locale={locale} market={market} client:load />
  <ContactForm locale={locale} client:load />
</DefaultLayout>
