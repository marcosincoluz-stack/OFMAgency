---
import BaseHead from '@/components/BaseHead.astro';
import { NavigationProvider } from '@/components/elements/navigation-provider';
import Footer from '@/components/layout/footer';
import { Navbar } from '@/components/layout/navbar';
import { DEFAULT_LOCALE, type Locale } from '@/lib/i18n';

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const { title, description, locale = Astro.locals.locale ?? DEFAULT_LOCALE } = Astro.props;
const pathname = Astro.url.pathname;
---

<html lang={locale}>
  <head>
    <BaseHead title={title} description={description} locale={locale} />
  </head>
  <body
    class={`h-screen antialiased flex flex-col [--header-height:calc(var(--spacing)*14)] lg:[--header-height:calc(var(--spacing)*23)]`}
  >
    <NavigationProvider client:load currentPath={pathname} />
    <Navbar pathname={pathname} locale={locale} client:load />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} client:idle />
  </body>
</html>
